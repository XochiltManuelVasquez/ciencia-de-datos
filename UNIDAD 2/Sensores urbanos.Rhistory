set.seed(42)
n <- 200
temp1 <- rnorm(n , 100, 5)
temp2 <- temp1 + rnorm(n, 0, 1)
presion1 <- rnorm (n, 50, 10)
vibracion <- (temp1 * 0.5) +rnorm(n, 0, 2)
datos.sensores <- data.frame(
temp_nucleo = temp1,
temp_escape = temp2,
presion_interna = presion1,
vibracion_motor = vibracion,
flujo_gas = rnorm(n, 20, 2),
oxigeno = rnorm(n, 15, 1),
co2 = temp1 * 0.2 + rnorm(n, 0, 0.5)
, humedad = runif(n, 30, 40),
voltaje = rnorm(n, 220, 2),
corriente = rnorm(n, 15, 0.5),
ruido_db = vibracion * 1.2 +rnorm(n, 0, 1),
eficiencia = 100 - (temp1 * 0.1)
)
head(datos.sensores)
pca_modelo <- prcomp(datos.sensores, center = TRUE, scale = TRUE)
head(pca_modelo)
summary(pca_modelo)
plot(pca_modelo, type="l", main="Grafico de Sedimentacion")
dbline(h=1, col="red", lty=2)
abline(h=1, col="red", lty=2)
