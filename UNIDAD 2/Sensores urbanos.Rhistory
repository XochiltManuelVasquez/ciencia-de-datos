library(dplyr)
library(ggplot2)
set.seed(2026)
n <- 600
datos_logistica <- data.frame(
envio_id = 1:n,
tipo_transporte = sample(c("Terrestre", "Aereo"), n, replace = TRUE),
clima = sample(c("Soleado", "Lluvia", "Tormenta"), n, replace = TRUE),
distancia_km = runif(n, 50, 2000),
costo_envio = runif(n, 500, 5000),
tiempo_entrega_hrs = NA
)
datos_logistica$tiempo_entrega_hrs <- 0.04 * datos_logistica$distancia_km +
rnorm(n, 5, 3)
datos_logistica$distancia_km[sample(1:n, 20)] <- NA
View(datos_logistica)
dist_mediana <- median(datos_logistica$distancia_km, na.rm = TRUE)
df_limpio <- datos_logistica %>%
mutate(distancia_km = ifelse(is.na(distancia_km), dist_mediana, distancia_km))
resumen_stats <- df_limpio %>%
summarise(
Tiempo_Medio = mean(tiempo_entrega_hrs),
Tiempo_DS = sd(tiempo_entrega_hrs)
)
print("Resumen Estadistico General:")
print(resumen_stats)
correlacion <- cor(df_limpio$distancia_km, df_limpio$tiempo_entrega_hrs)
print("Correlacion entre distancia y tiempo de entrega:")
print(correlacion)
resumen_transporte <- df_limpio %>%
group_by(tipo_transporte) %>%
summarise(
Tiempo_Promedio = mean(tiempo_entrega_hrs),
Costo_Promedio = mean(costo_envio)
)
print("Resumen por tipo de transporte:")
print(resumen_transporte)
prueba_t <- t.test(tiempo_entrega_hrs ~ tipo_transporte, data = df_limpio)
p_val <- prueba_t$p.value
if(p_val < 0.05){
print("CONCLUSION: El p-value es menor a 0.05. RECHAZAMOS H0")
print("Existe evidencia estadistica de diferencia en el tiempo de entrega entre modalidades.")
} else {
print("CONCLUSION: El p-value es mayor a 0.05. NO se rechaza H0")
print("No existe evidencia estadistica de diferencia en el tiempo de entrega entre modalidades.")
}
print(p_val)
ggplot(df_limpio, aes(x = distancia_km, y = tiempo_entrega_hrs)) +
geom_point(aes(color = tipo_transporte), alpha = 0.6) +
geom_smooth(method = "lm", color = "#1B396A") +
labs(
title = "Relacion entre Distancia y Tiempo de Entrega",
subtitle = "Analisis logistico de envios",
x = "Distancia (km)",
y = "Tiempo de entrega (horas)",
color = "Tipo de transporte"
) +
theme_minimal()
ggplot(df_limpio, aes(x = tipo_transporte, y = tiempo_entrega_hrs, fill = tipo_transporte)) +
geom_boxplot(outlier.color = "red") +
scale_fill_manual(values = c("#1B396A", "#B08A4F")) +
labs(
title = "Distribucion del tiempo de entrega por modalidad",
x = "Tipo de transporte",
y = "Tiempo de entrega (horas)"
) +
theme_classic()
savehistory("~/C. DATOS/practica 3.Rhistory")
