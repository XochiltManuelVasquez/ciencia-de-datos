library(dplyr)
library(ggplot2)
set.seed(2026)
n <- 500
datos_industriales <- data.frame()
datos_industriales <- data.frame(
lote_id = 1:n,
turno = sample(c("Matutino", "Vespertino"), n, replace = TRUE)
temperatura = rnorm(n, mean = 75, sd = 10)
datos_industriales <- data.frame(
lote_id = 1:n,
turno = sample(c("Matutino", "Vespertino"), n, replace = TRUE),
temperatura = rnorm(n, mean = 75, sd = 10),
presion = runif(n, 90, 120),
tasa_error = NA)
View(datos_industriales)
datos_industriales$tasa_error <- 0.5 * datos_industriales$temperatura +
rnorm(n, 0, 2)
datos_industriales$temperatura[sample(1:n, 15)] <- NA
temp_media <- mean(datos_industriales$temperatura, na.rm = TRUE)
temp_media
df_limpio <- datos_industriales %>% mutate(temperatura = ifelse(is.na(temperatura), temp_media, temperatura))
View(df_limpio)
resumen_stats <- df_limpio %>%
summarise(
Temp_Media = mean(temperatura),
Temp_DS = sd(temperatura),
Error_Media = mena(tasa_error),
Correlacion = cor(temperatura, tasa_error)
)
resumen_stats <- df_limpio %>%
summarise(
Temp_Media = mean(temperatura),
Temp_DS = sd(temperatura),
Error_Media = mean(tasa_error),
Correlacion = cor(temperatura, tasa_error)
)
print("Resumen Estadistico General:")
print(resumen_stats)
resumen_turnos <- df_limpio %>% group_by(turno) %>%
summarise(
Error_Promedio = mean(tasa_error),
Temp_Max = max(temperatura))
resumen_turnos
ggplot(df_limpio, aes(x = temperatura, y = tasa_error)) +
geom_point(aes(color = turno), alpha = 0.6) +
geom_smooth(method = "lm", color = "#1B396A") +
labs(
title = "Impacto termico en la calidad de produccion",
subtitle = "Analisis de correlacion temperatura-error",
x = "Temperatura de operacion (ºC)",
y = "Tasa de error (%)",
color = "Turno de trabajo"
) +
theme_minimal()
ggplot(df_limpio, aes(x = turno, y = tasa_error, fill = turno)) +
geom_boxplot(outlier.color = "red")+
scale_fill_manual(values = c("#1B396A", "#B08A4F")) +
labs(
title = "Distribucion de errores por turno",
x = "Turno",
y = "Tasa de error (%) "
) +
theme_classic()
prueba_t <- t.test(tasa_error ~ turno, data = df_limpio)
p_val <- prueba_t$p.value
if(p_val < 0.05){
print("CONCLUSION: El p~value es menor a 0.05. RECHAZAMOS H0")
print("Existe evidencia estadistica de que un turno es mas eficiente que otro.")
} else {}
p_val
savehistory("~/C. DATOS/Datos Industriales.Rhistory")
