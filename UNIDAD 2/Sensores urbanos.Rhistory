set.seed(456)
n <- 400
# Datos base de sensores urbanos
datos_urbanos <- data.frame(
temp_ambiente = rnorm(n, 28, 4),
humedad_rel = rnorm(n, 60, 10),
co2_ppm = NA,
no2_ppb = NA,
particulas_pm25 = NA,
nivel_ruido_db = NA,
densidad_vehiculos = rnorm(n, 120, 30),
velocidad_viento = rnorm(n, 15, 5),
radiacion_solar = rnorm(n, 800, 100),
conteo_peatones = rnorm(n, 50, 15)
)
# Creación de Redundancia y Correlación (Lógica de ciudad)
datos_urbanos$co2_ppm <- (datos_urbanos$densidad_vehiculos * 3.5) + rnorm(n, 300, 50)
datos_urbanos$no2_ppb <- (datos_urbanos$co2_ppm * 0.1) + rnorm(n, 5, 2)
datos_urbanos$particulas_pm25 <- (datos_urbanos$co2_ppm * 0.05) + rnorm(n, 10, 3)
datos_urbanos$nivel_ruido_db <- (datos_urbanos$densidad_vehiculos * 0.2) + 50 + rnorm(n, 0, 5)
head(datos_urbanos)
