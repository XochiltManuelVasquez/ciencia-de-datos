set.seed(123)
n <- 300
datos_red <- data.frame(
duracion_ms = rnorm(n, 50, 10),
paquetes_enviados = rnorm(n, 100, 20),
bytes_enviados = NA,
errores_checksum = rpois(n, 2),
reintentos_tcp = NA,
latencia_avg = rnorm(n, 15, 5),
jitter = rnorm(n, 2, 0.5),
carga_cpu_router = NA,
uso_memoria_sw = rnorm(n, 40, 10),
peticiones_http = rnorm(n, 200, 50)
)
datos_red$bytes_enviados <- datos_red$paquetes_enviados * 1500 + rnorm(n, 0, 500)
datos_red$reintentos_tcp <- datos_red$errores_checksum * 1.5 + rnorm(n, 0, 0.5)
datos_red$carga_cpu_router <- (datos_red$paquetes_enviados * 0.4) + (datos_red$latencia_avg * 0.2)
head(datos_red)
pca_red <- prcomp(datos_red, center = TRUE, scale. = TRUE)
head(pca_red)
summary(pca_red)
plot(pca_red, type = "l", main = "Screen Plot: Trafico de red")
View(datos_red)
head(pca_red)
biplot(pca_red, cex = 0.8, main = "Mapa de estado de red")
